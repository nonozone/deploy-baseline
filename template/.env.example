# Compose 项目名
COMPOSE_PROJECT_NAME=sampleapp

# 数据库
DB_USER=sampleapp
DB_PASSWORD=change-me
DB_NAME=sampleapp
DB_HOST=127.0.0.1
DB_PORT=5432

# 应用
APP_PORT=8000
APP_PUBLISH_IP=127.0.0.1
APP_PUBLISH_PORT=8000

# 镜像
APP_IMAGE=sampleapp:latest

# 其他项目变量在这里继续追加
# 例如：
# APP_ENV=development
# PUBLIC_API_URL=http://127.0.0.1:8000
