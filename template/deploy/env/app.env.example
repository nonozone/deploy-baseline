# project / runtime
APP_ENV=staging
APP_IMAGE=ghcr.io/example-org/sampleapp:replace-with-git-sha

# publish ports
APP_PUBLISH_IP=127.0.0.1
APP_PUBLISH_PORT=8000
APP_INTERNAL_PORT=8000
APP_HEALTHCHECK_PATH=/health
APP_HEALTHCHECK_TIMEOUT=120

# database
DB_USER=sampleapp
DB_PASSWORD=replace-me
DB_NAME=sampleapp
DB_HOST=db
DB_PORT=5432

# auth / secrets
# SESSION_SECRET=replace-me

# provider-specific config
# PROVIDER_REGION=us-east-1

# observability / verification
# LOG_LEVEL=info
