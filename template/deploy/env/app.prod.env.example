# 生产运行时变量示例
APP_ENV=production
APP_IMAGE=sampleapp:replace-with-git-sha
APP_PUBLISH_IP=127.0.0.1
APP_PUBLISH_PORT=8000
APP_INTERNAL_PORT=8000
APP_HEALTHCHECK_PATH=/health
APP_HEALTHCHECK_TIMEOUT=120

DB_USER=sampleapp
DB_PASSWORD=change-me-in-production
DB_NAME=sampleapp
DB_HOST=db
DB_PORT=5432

# 在这里继续补充项目自己的生产变量
# 例如：
# SECRET_KEY=replace-me
# PUBLIC_API_URL=https://api.example.com
