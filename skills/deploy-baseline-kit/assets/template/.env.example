# 本地开发变量（.env.example 是本地 .env 的变量基准来源）
# 新增变量时，同步在此文件中追加 key 与本地默认值
# 生产环境变量请在 deploy/env/app.prod.env.example 中维护

# Compose 项目名
COMPOSE_PROJECT_NAME=sampleapp

# 本地运行模式（docker = 全量 Docker；mixed = 部分本地运行）
LOCAL_RUNTIME_MODE=docker

# 应用端口
APP_PORT=8000
APP_PUBLISH_IP=127.0.0.1
APP_PUBLISH_PORT=8000
APP_INTERNAL_PORT=8000
APP_HEALTHCHECK_PATH=/health
APP_HEALTHCHECK_TIMEOUT=120

# 应用镜像标识（本地开发用）
APP_IMAGE=sampleapp:dev

# 数据库
DB_USER=sampleapp
DB_PASSWORD=
DB_NAME=sampleapp
DB_HOST=db
DB_PORT=5432

# 认证 / 密钥（按项目实际需要取消注释）
# SESSION_SECRET=

# 可观测性（按项目实际需要取消注释）
# LOG_LEVEL=info
