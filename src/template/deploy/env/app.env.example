# canonical env source
# 强制规则：开发 `deploy/env/app.dev.env` 与生产 `deploy/env/app.prod.env` 都必须从本文件创建或同步

# project / runtime
COMPOSE_PROJECT_NAME=sampleapp
LOCAL_RUNTIME_MODE=docker
APP_PORT=8000
APP_PUBLISH_IP=127.0.0.1
APP_PUBLISH_PORT=8000
APP_INTERNAL_PORT=8000
APP_HEALTHCHECK_PATH=/health
APP_HEALTHCHECK_TIMEOUT=120
APP_IMAGE=

# database
DB_USER=sampleapp
DB_PASSWORD=
DB_NAME=sampleapp
DB_HOST=db
DB_PORT=5432

# auth / secrets
# SESSION_SECRET=
# SECRET_KEY=

# provider-specific config
# PROVIDER_REGION=us-east-1
# PUBLIC_API_URL=https://api.example.com

# observability / verification
# LOG_LEVEL=info
